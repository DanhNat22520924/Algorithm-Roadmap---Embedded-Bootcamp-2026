class Solution {
public:
    double findMaxAverage(vector<int>& nums, int k) {
        double sum = 0;
        // mx: lưu tổng lớn nhất của cửa sổ kích thước k
        double mx = INT_MIN;
        // tính trước tổng của k-1 phần tử đầu tiên
        for(int i=0; i<k-1; i++ ) {
            sum += nums[i];
        }
        // bắt đầu sliding window
        for (int i=k-1; i<nums.size(); i++) {
            sum += nums[i];
            mx = max(mx, sum);
            sum -= nums[i-k+1];
        }
        return mx/k; // trung bình = tổng lớn nhất / k
    }
};
